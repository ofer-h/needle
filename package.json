{
  "name": "needle",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "description": "Needle monorepo — transition coach. Desktop (Electron) + shared packages today; cloud (web/server/mobile) on a parallel track.",
  "scripts": {
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "build": "turbo run build",
    "test": "turbo run test",
    "start": "pnpm --filter @needle/desktop run start",
    "package": "pnpm --filter @needle/desktop run package",
    "make": "pnpm --filter @needle/desktop run make"
  },
  "author": "Omri and Ofer",
  "license": "MIT",
  "devDependencies": {
    "turbo": "^2.9.15"
  }
}
