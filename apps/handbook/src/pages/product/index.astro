---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Product" description="Product positioning and direction for Needle.">
  <h1>Product</h1>
  <p>
    Needle's product story: transition coach at the switch, calm AI-guided daily flow, and
    accountability without aggression.
  </p>
  <div class="card-grid">
    <a class="card" href="/product/positioning/">
      <h3>Positioning & pitch</h3>
      <p>One-liners, elevator pitch, how to talk about Needle in person.</p>
    </a>
    <a class="card" href="/product/competitive/">
      <h3>Competitive landscape</h3>
      <p>Market buckets, white space, differentiation matrix.</p>
    </a>
    <a class="card" href="/product/daily-flow/">
      <h3>Daily flow direction</h3>
      <p>Today-first, flexible vs anchored work, AI as companion.</p>
    </a>
    <a class="card" href="/product/accountability/">
      <h3>Accountability & scoring</h3>
      <p>Transition-ritual adherence, three delivery modes, open questions.</p>
    </a>
  </div>
</Layout>
